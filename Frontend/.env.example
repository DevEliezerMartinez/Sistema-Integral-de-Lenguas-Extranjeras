# .env.example - Frontend
# -------------------------------------------------------
# MODO DEV LOCAL (npm run dev):
#   VITE_API_URL=http://localhost:8000
#
# MODO DOCKER (build.sh / docker compose):
#   Dejar VACIO - el Nginx sirve frontend y backend desde
#   la misma IP/puerto, por lo que las rutas son relativas.
#   El build arg VITE_API_URL lo gestiona docker-compose.yml
#   automaticamente con la IP del sistema.
# -------------------------------------------------------
VITE_API_URL=http://localhost:8000
